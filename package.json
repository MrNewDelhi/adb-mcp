{
  "name": "@mrnewdelhi/adb-mcp",
  "version": "0.1.0",
  "description": "A broad Android Debug Bridge MCP server with typed tools for devices, apps, files, logs, settings, intents, screenshots, networking, and raw adb access.",
  "type": "module",
  "bin": {
    "adb-mcp": "./dist/index.js"
  },
  "files": [
    "docs",
    "dist",
    "README.md",
    "SECURITY.md",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "npm run typecheck && npm run test:mcp && npm run validate:skill",
    "test:mcp": "npm run build && node tests/mcp-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:skill": "python3 \"${CODEX_HOME:-$HOME/.codex}/skills/.system/skill-creator/scripts/quick_validate.py\" skills/adb-mcp"
  },
  "keywords": [
    "adb",
    "android",
    "mcp",
    "model-context-protocol",
    "automation",
    "testing"
  ],
  "author": "MrNewDelhi",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
